# Copy this file to .env and fill in the mailbox used to send NexCart codes.
# For Gmail, create a Google App Password (not your normal Gmail password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Django deployment configuration. Keep DEBUG=True for local development only.
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-before-deploying
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
